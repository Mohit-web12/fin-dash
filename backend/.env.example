# Copy to .env and adjust for your environment. Never commit the real .env.

# SQLAlchemy DB URL. Default is a local SQLite file next to this repo.
DATABASE_URL=sqlite:///./finance.db

# Secret used to sign JWTs — set to a long random string in production.
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Comma-separated list of origins allowed to call this API from a browser.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Seeded on first boot if no users exist yet. Log in with these, then treat
# them as compromised in any environment other than your own machine.
SEED_USER_EMAIL=demo@example.com
SEED_USER_PASSWORD=changeme123
